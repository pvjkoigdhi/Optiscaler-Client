<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">設定</x:String>
    <x:String x:Key="TxtSettingsDesc">アプリケーションの設定を管理</x:String>
    <x:String x:Key="TxtAppPrefs">アプリ設定</x:String>
    <x:String x:Key="TxtCacheMgmt">ローカルキャッシュ管理</x:String>
    <x:String x:Key="TxtCacheDesc">ダウンロードしたOptiScalerバージョンをローカルストレージから表示・削除してスペースを解放します。</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  管理</x:String>
    <x:String x:Key="TxtLanguage">アプリケーション言語</x:String>
    <x:String x:Key="TxtLanguageDesc">ユーザーインターフェースの言語を変更します。</x:String>
    <x:String x:Key="TxtClose">閉じる</x:String>
    <x:String x:Key="TxtGotIt">了解</x:String>
    <x:String x:Key="TxtAppRepoTitle">アプリリポジトリ</x:String>
    <x:String x:Key="TxtAppRepoDesc">更新とフィードバックのためのターゲットGitHubリポジトリ（所有者/リポジトリ名）。</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">ガイド</x:String>
    <x:String x:Key="TxtGuideHeader">Optiscaler Clientの使用方法</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">ゲームを向上させる簡単な手順</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. ゲームを見つける</x:String>
    <x:String x:Key="TxtGuideStep1Desc">「ゲームをスキャン」ボタンをクリックして、アプリにSteam、Epic、GOG、またはXboxからインストールされたゲームを自動的に見つけさせます。スタンドアローンゲームがある場合は「手動で追加」ボタンを確認してください。</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. ゲームを管理する</x:String>
    <x:String x:Key="TxtGuideStep2Desc">リスト内のゲームの横にある「管理」をクリックします。ウィンドウが開き、その特定のゲームのOptiScalerモッドをインストールまたは更新できます。</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. OptiScalerをインストール</x:String>
    <x:String x:Key="TxtGuideStep3Desc">管理ウィンドウ内で、OptiScalerバージョンとオプションを選択します。クイックセットアップには「自動インストール」を使用します。自動インストールが失敗した場合、または正しい実行可能ファイル（.exe）が見つからない場合は、「手動インストール」を使用してゲームの実行可能ファイルを自分で選択します。</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. ゲームをプレイ</x:String>
    <x:String x:Key="TxtGuideStep4Desc">インストール後、通常通りゲームを起動します。ゲーム内で「Insert」キーを使用してOptiScalerメニューを開き、設定を調整してください！</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client</x:String>
    <x:String x:Key="TxtBtnScan">⟳  ゲームをスキャン</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  手動で追加</x:String>
    <x:String x:Key="TxtTipSettings">設定</x:String>
    <x:String x:Key="TxtTipComponent">コンポーネントバージョン</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  NukemFGを更新</x:String>
    <x:String x:Key="TxtTipUpdateNukem">新しいNukemFGバージョンが利用可能です。更新されたDLLを提供するためにクリックしてください。</x:String>
    <x:String x:Key="TxtDefaultGpu">GPUを検出中…</x:String>
    <x:String x:Key="TxtManageGame">管理</x:String>
    <x:String x:Key="TxtStatusReady">準備完了</x:String>
    <x:String x:Key="TxtScanningTitle">ゲームをスキャン中...</x:String>
    <x:String x:Key="TxtScanningDesc">すべてのプラットフォームでゲームを検索中...</x:String>
    <x:String x:Key="TxtSearchGames">ゲームを検索...</x:String>
    <x:String x:Key="TxtRemoveGameTip">手動で追加されたゲームを削除</x:String>
    <x:String x:Key="TxtRemoveGameTitle">ゲームを削除</x:String>
    <x:String x:Key="TxtRemoveGameConfirm">リストから '{0}' を削除してもよろしいですか？</x:String>

    <!-- ManageCacheWindow -->
    <x:String x:Key="TxtManageCacheTitle">ローカルバージョンを管理</x:String>
    <x:String x:Key="TxtLocalVersions">ローカルバージョン</x:String>
    <x:String x:Key="TxtManageCacheDesc">ダウンロードしたOptiScalerキャッシュを管理</x:String>
    <x:String x:Key="TxtDownloadedVersions">ダウンロードしたOptiScalerバージョン：</x:String>
    <x:String x:Key="TxtDeleteIcon">🗑️ 削除</x:String>
    <x:String x:Key="TxtNoVersions">現在ダウンロードされているバージョンはありません。</x:String>
    <x:String x:Key="TxtToastSuccess">成功</x:String>
    <x:String x:Key="TxtConfirmDelTitle">削除を確認</x:String>
    <x:String x:Key="TxtConfirmDelMsg">このバージョンを削除してもよろしいですか？</x:String>
    <x:String x:Key="TxtCancel">キャンセル</x:String>
    <x:String x:Key="TxtDeletePlain">削除</x:String>
    <x:String x:Key="TxtConfirmDelFormat">OptiScaler v{0} をローカルストレージから削除してもよろしいですか？</x:String>
    <x:String x:Key="TxtDeletedSuccessFormat">OptiScaler v{0} が正常に削除されました。</x:String>
    <x:String x:Key="TxtFailedDeleteFormat">バージョンの削除に失敗しました：{0}</x:String>
    <x:String x:Key="TxtError">エラー</x:String>
    <x:String x:Key="TxtCurrentSelection">現在選択中</x:String>
    <x:String x:Key="TxtVersionStored">1バージョンがローカルに保存されています。</x:String>
    <x:String x:Key="TxtVersionsStored">{0}バージョンがローカルに保存されています。</x:String>

    <!-- ComponentInfoWindow -->
    <x:String x:Key="TxtComponentTitle">コンポーネントバージョン</x:String>
    <x:String x:Key="TxtComponentDesc">インストールされているOptiScalerツールキットのバージョン</x:String>
    <x:String x:Key="TxtBtnGuide">📖 ガイド</x:String>
    <x:String x:Key="TxtUpdateAvail">更新利用可能</x:String>
    <x:String x:Key="TxtAppVersionLbl">アプリバージョン</x:String>

    <!-- ManageGameWindow -->
    <x:String x:Key="TxtManageGameWindow">ゲームを管理</x:String>
    <x:String x:Key="TxtOpenFolder">📂  フォルダを開く</x:String>
    <x:String x:Key="TxtOptiStatus">OptiScalerステータス</x:String>
    <x:String x:Key="TxtDetectedComponents">検出されたコンポーネント</x:String>
    <x:String x:Key="TxtConfirmUninstallTitle">アンインストールを確認</x:String>
    <x:String x:Key="TxtConfirmUninstallMsg">OptiScalerをアンインストールしてもよろしいですか？&#x0a;バックアップされた元のファイルのみが復元されます。</x:String>
    <x:String x:Key="TxtUninstall">✕ アンインストール</x:String>
    <x:String x:Key="TxtVersionLbl">バージョン：</x:String>
    <x:String x:Key="TxtInjectionLbl">インジェクション：</x:String>
    <x:String x:Key="TxtInstallOpti">✦ 自動インストール</x:String>
    <x:String x:Key="TxtBtnManualInstall">✦ 手動インストール</x:String>
    <x:String x:Key="TxtUpdateOpti">↑ 自動更新 / 再インストール</x:String>
    <x:String x:Key="TxtUpdateOptiManual">↑ 手動更新 / 再インストール</x:String>
    <x:String x:Key="TxtFakenvapiTip">AMD/Intel GPUでDLSS FGを有効にするためにNukem modで必須</x:String>
    <x:String x:Key="TxtNukemTip">フレーム生成のためのNukemのDLSSG-to-FSR3 mod</x:String>
    <x:String x:Key="TxtFakenvapiHelpTip">ゲームをだましてNVIDIAグラフィックカードを検出させ、ハードウェア制限を回避してAMDまたはIntel GPUでDLSS技術を有効にできるようにします。</x:String>
    <x:String x:Key="TxtNukemHelpTip">Nukemによるmodで、ネイティブのDLSSフレーム生成をAMD FSR 3フレーム生成に置き換え、互換性のある任意のGPUでフレーム生成を有効にします。</x:String>

    <x:String x:Key="TxtOptiInstalled">OptiScalerがインストール済み</x:String>
    <x:String x:Key="TxtOptiNotInstalled">未インストール</x:String>
    <x:String x:Key="TxtNoOptiDetected">バージョンが検出されません</x:String>
    <x:String x:Key="TxtOptiLatest"> （最新）</x:String>
    <x:String x:Key="TxtInstallingFormat">OptiScaler v{0}をダウンロード中... {1}%</x:String>
    <x:String x:Key="TxtExtractingFormat">v{0}を抽出・インストール中...</x:String>
    <x:String x:Key="TxtInstallSuccessFormat">{0}が正常にインストールされました！</x:String>
    <x:String x:Key="TxtDownloadErrorPrefix">OptiScalerのダウンロードに失敗しました：{0}</x:String>
    <x:String x:Key="TxtOptiUninstallSuccess">OptiScalerが正常にアンインストールされました。</x:String>
    <x:String x:Key="TxtOptiUninstallFail">アンインストールに失敗しました：{0}</x:String>
    <x:String x:Key="TxtInstallSuccessTitle">インストール成功</x:String>

    <!-- ManualDownloadDialog -->
    <x:String x:Key="TxtManualTitle">手動ファイルが必要</x:String>
    <x:String x:Key="TxtDownloadFrom">ダウンロード元： </x:String>
    <x:String x:Key="TxtReqFileLbl">必要なファイル： </x:String>
    <x:String x:Key="TxtBrowse">参照…</x:String>
    <x:String x:Key="TxtConfirmBtn">✓ 確認</x:String>
    
    <x:String x:Key="TxtManualUpdateTitle">🔄 手動更新利用可能</x:String>
    <x:String x:Key="TxtManualUpdateInst">NukemFGの新しいバージョンがNexus Modsで利用可能です。&#x0a;以下のリンクから更新されたファイルをダウンロードし、DLL（またはZIP）を選択してください：</x:String>
    <x:String x:Key="TxtManualUpdateHint">「参照」をクリックして、更新されたファイルのあるDLL、ZIP、またはフォルダを選択します。</x:String>
    <x:String x:Key="TxtBtnUpdate">更新</x:String>
    <x:String x:Key="TxtBtnLater">後で</x:String>

    <!-- Help View Strings -->
    <x:String x:Key="TxtAboutTitle">について</x:String>
    <x:String x:Key="TxtFeedbackTitle">フィードバック</x:String>
    <x:String x:Key="TxtFeedbackDesc">機能をリクエストしたりバグを報告したりする場合は、GitHubリポジトリでissueを開いてください。</x:String>
    <x:String x:Key="TxtBuildDateLbl">最終ビルド日</x:String>
    <x:String x:Key="TxtCheckUpdatesBtn">更新を確認</x:String>
    <x:String x:Key="TxtGithubBtn">GitHubリポジトリ</x:String>

    <x:String x:Key="TxtManualReqTitle">⚠️ 手動ファイルが必要</x:String>
    <x:String x:Key="TxtManualReqInst">NukemFGは自動的にダウンロードできません。&#x0a;Nexus Modsからファイルをダウンロードし、以下のDLL（またはZIP）を選択してください：</x:String>
    <x:String x:Key="TxtManualReqHint">「参照」をクリックして、DLLを直接、ZIP、または抽出されたフォルダを選択します。</x:String>
    <x:String x:Key="TxtBtnConfirm">確認</x:String>
    <x:String x:Key="TxtBtnSkip">スキップ</x:String>

    <!-- CodeBehind additions -->
    <x:String x:Key="TxtCheckingUpdates">更新を確認中…</x:String>
    <x:String x:Key="TxtReady">準備完了</x:String>
    <x:String x:Key="TxtNukemUpdateSuccess">NukemFGが正常に更新されました。</x:String>
    <x:String x:Key="TxtActualizacionTitle">更新</x:String>
    <x:String x:Key="TxtLoadedGamesFormat">{0}ゲームが読み込まれました。</x:String>
    <x:String x:Key="TxtScanningShort">ゲームをスキャン中...</x:String>
    <x:String x:Key="TxtScanCompleteFormat">スキャン完了。合計ゲーム：{0}</x:String>
    <x:String x:Key="TxtErrorFormat">エラー：{0}</x:String>
    <x:String x:Key="TxtSelectExe">ゲーム実行可能ファイルを選択</x:String>
    <x:String x:Key="TxtGameDuplicate">このゲームはすでにリストにあります。</x:String>
    <x:String x:Key="TxtDuplicateTitle">重複ゲーム</x:String>
    <x:String x:Key="TxtAddedRefFormat">{0}が手動で追加されました。</x:String>
    <x:String x:Key="TxtNoGpu">⚠️ GPUが検出されません</x:String>
    <x:String x:Key="TxtNoGpuTip">このシステムでGPUが検出されませんでした</x:String>
    <x:String x:Key="TxtGpuFail">⚠️ GPU検出に失敗</x:String>
    <x:String x:Key="TxtGpuFailTipFormat">GPU検出エラー：{0}</x:String>
    <x:String x:Key="TxtAutoScan">起動時に自動スキャン</x:String>
    <x:String x:Key="TxtAutoScanDesc">起動時にリストが空の場合に自動的にゲームをスキャンします。</x:String>
    <x:String x:Key="TxtAnimations">アニメーションを有効にする</x:String>
    <x:String x:Key="TxtAnimationsDesc">インターフェース全体で滑らかな遷移とアニメーションを有効にします</x:String>

    <!-- App Update -->
    <x:String x:Key="TxtUpdateAvailableTitle">更新利用可能</x:String>
    <x:String x:Key="TxtUpdateAvailableMsg">Optiscaler Clientの新しいバージョンが利用可能です（v{0}）。&#x0a;今すぐダウンロードしてインストールしますか？</x:String>
    <x:String x:Key="TxtUpdatingApp">アプリを更新中...</x:String>
    <x:String x:Key="TxtUpdateReady">更新準備完了</x:String>
    <x:String x:Key="TxtUpdateReadyMsg">更新がダウンロードされました。インストールを完了するために、アプリケーションは今すぐ再起動します。</x:String>
    <x:String x:Key="TxtUpdateError">更新エラー</x:String>
    <x:String x:Key="TxtNoUpdateFound">アプリケーションはすでに最新です。</x:String>
    <x:String x:Key="TxtUpdateCheckError">更新の確認中に問題が発生しました。後でもう一度お試しください。</x:String>

</ResourceDictionary>
