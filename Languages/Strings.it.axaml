    <!-- App Update -->
    <x:String x:Key="TxtUpdateAvailableTitle">Aggiornamento disponibile</x:String>
    <x:String x:Key="TxtUpdateAvailableMsg">Una nuova versione di Optiscaler Client è disponibile (v{0}).&#x0a;Vuoi scaricarla e installarla ora?</x:String>
