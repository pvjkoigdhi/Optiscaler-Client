    <x:String x:Key="TxtInstallingFormat">下載OptiScaler v{0}... {1}%</x:String>
    <x:String x:Key="TxtExtractingFormat">解壓縮並安裝v{0}...</x:String>
    <x:String x:Key="TxtInstallSuccessFormat">{0}安裝成功！</x:String>
    <x:String x:Key="TxtDownloadErrorPrefix">下載OptiScaler失敗：{0}</x:String>
