    <!-- ManualDownloadDialog -->
    <x:String x:Key="TxtManualTitle">需要手動檔案</x:String>
    <x:String x:Key="TxtDownloadFrom">下載自： </x:String>
    <x:String x:Key="TxtReqFileLbl">所需檔案： </x:String>
