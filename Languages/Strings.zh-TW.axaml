<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">設定</x:String>
    <x:String x:Key="TxtSettingsDesc">管理應用程式偏好設定</x:String>
    <x:String x:Key="TxtAppPrefs">應用程式偏好設定</x:String>
    <x:String x:Key="TxtCacheMgmt">本機快取管理</x:String>
    <x:String x:Key="TxtCacheDesc">檢視並刪除本機儲存中已下載的OptiScaler版本以釋放空間。</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  管理</x:String>
    <x:String x:Key="TxtLanguage">應用程式語言</x:String>
    <x:String x:Key="TxtLanguageDesc">變更使用者介面語言。</x:String>
    <x:String x:Key="TxtClose">關閉</x:String>
    <x:String x:Key="TxtGotIt">知道了</x:String>
    <x:String x:Key="TxtAppRepoTitle">應用程式儲存庫</x:String>
    <x:String x:Key="TxtAppRepoDesc">用於更新和回饋的目標GitHub儲存庫（擁有者/儲存庫名稱）。</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">指南</x:String>
    <x:String x:Key="TxtGuideHeader">如何使用Optiscaler Client</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">增強遊戲的簡單步驟</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. 找到您的遊戲</x:String>
    <x:String x:Key="TxtGuideStep1Desc">點擊「掃描遊戲」按鈕，讓應用程式自動尋找從Steam、Epic、GOG或Xbox安裝的遊戲。如果您有獨立遊戲，請勾選「手動新增」按鈕。</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. 管理遊戲</x:String>
    <x:String x:Key="TxtGuideStep2Desc">在清單中您的遊戲旁邊，點擊「管理」。將開啟一個視窗，允許您為該特定遊戲安裝或更新OptiScaler模組。</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. 安裝OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Desc">在管理視窗內，選擇您的OptiScaler版本和選項。使用「自動安裝」進行快速設定。如果自動安裝失敗或無法找到正確的可執行檔（.exe），請使用「手動安裝」自己選擇遊戲的可執行檔。</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. 玩遊戲</x:String>
    <x:String x:Key="TxtGuideStep4Desc">安裝後，正常啟動您的遊戲。在遊戲內，使用「Insert」鍵開啟OptiScaler選單來調整您的設定！</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client</x:String>
    <x:String x:Key="TxtBtnScan">⟳  掃描遊戲</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  手動新增</x:String>
    <x:String x:Key="TxtTipSettings">設定</x:String>
    <x:String x:Key="TxtTipComponent">元件版本</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  更新NukemFG</x:String>
    <x:String x:Key="TxtTipUpdateNukem">新的NukemFG版本可用。點擊提供更新的DLL。</x:String>
    <x:String x:Key="TxtDefaultGpu">偵測GPU中…</x:String>
    <x:String x:Key="TxtManageGame">管理</x:String>
    <x:String x:Key="TxtStatusReady">就緒</x:String>
    <x:String x:Key="TxtScanningTitle">掃描遊戲中...</x:String>
    <x:String x:Key="TxtScanningDesc">在所有平台上尋找遊戲...</x:String>
    <x:String x:Key="TxtSearchGames">搜尋遊戲...</x:String>
    <x:String x:Key="TxtRemoveGameTip">刪除手動新增的遊戲</x:String>
    <x:String x:Key="TxtRemoveGameTitle">刪除遊戲</x:String>
    <x:String x:Key="TxtRemoveGameConfirm">您確定要從清單中刪除 '{0}' 嗎？</x:String>

    <!-- ManageCacheWindow -->
    <x:String x:Key="TxtManageCacheTitle">管理本機版本</x:String>
    <x:String x:Key="TxtLocalVersions">本機版本</x:String>
    <x:String x:Key="TxtManageCacheDesc">管理已下載的OptiScaler快取</x:String>
    <x:String x:Key="TxtDownloadedVersions">已下載的OptiScaler版本：</x:String>
    <x:String x:Key="TxtDeleteIcon">🗑️ 刪除</x:String>
    <x:String x:Key="TxtNoVersions">目前沒有下載的版本。</x:String>
    <x:String x:Key="TxtToastSuccess">成功</x:String>
    <x:String x:Key="TxtConfirmDelTitle">確認刪除</x:String>
    <x:String x:Key="TxtConfirmDelMsg">您確定要刪除此版本嗎？</x:String>
    <x:String x:Key="TxtCancel">取消</x:String>
    <x:String x:Key="TxtDeletePlain">刪除</x:String>
    <x:String x:Key="TxtConfirmDelFormat">您確定要從本機儲存中刪除OptiScaler v{0}嗎？</x:String>
    <x:String x:Key="TxtDeletedSuccessFormat">OptiScaler v{0}刪除成功。</x:String>
    <x:String x:Key="TxtFailedDeleteFormat">刪除版本失敗：{0}</x:String>
    <x:String x:Key="TxtError">錯誤</x:String>
    <x:String x:Key="TxtCurrentSelection">目前選擇</x:String>
    <x:String x:Key="TxtVersionStored">1個版本本機儲存。</x:String>
    <x:String x:Key="TxtVersionsStored">{0}個版本本機儲存。</x:String>

    <!-- ComponentInfoWindow -->
    <x:String x:Key="TxtComponentTitle">元件版本</x:String>
    <x:String x:Key="TxtComponentDesc">已安裝的OptiScaler工具組版本</x:String>
    <x:String x:Key="TxtBtnGuide">📖 指南</x:String>
    <x:String x:Key="TxtUpdateAvail">更新可用</x:String>
    <x:String x:Key="TxtAppVersionLbl">應用程式版本</x:String>

    <!-- ManageGameWindow -->
    <x:String x:Key="TxtManageGameWindow">管理遊戲</x:String>
    <x:String x:Key="TxtOpenFolder">📂  開啟資料夾</x:String>
    <x:String x:Key="TxtOptiStatus">OptiScaler狀態</x:String>
    <x:String x:Key="TxtDetectedComponents">偵測到的元件</x:String>
    <x:String x:Key="TxtConfirmUninstallTitle">確認解除安裝</x:String>
    <x:String x:Key="TxtConfirmUninstallMsg">您確定要解除安裝OptiScaler嗎？&#x0a;只有備份的原始檔案將被還原。</x:String>
    <x:String x:Key="TxtUninstall">✕ 解除安裝</x:String>
    <x:String x:Key="TxtVersionLbl">版本：</x:String>
    <x:String x:Key="TxtInjectionLbl">注入：</x:String>
    <x:String x:Key="TxtInstallOpti">✦ 自動安裝</x:String>
    <x:String x:Key="TxtBtnManualInstall">✦ 手動安裝</x:String>
    <x:String x:Key="TxtUpdateOpti">↑ 自動更新 / 重新安裝</x:String>
    <x:String x:Key="TxtUpdateOptiManual">↑ 手動更新 / 重新安裝</x:String>
    <x:String x:Key="TxtFakenvapiTip">AMD/Intel GPU啟用DLSS FG與Nukem模組所需</x:String>
    <x:String x:Key="TxtNukemTip">Nukem的DLSSG-to-FSR3模組用於幀生成</x:String>
    <x:String x:Key="TxtFakenvapiHelpTip">欺騙遊戲偵測NVIDIA顯卡，允許您繞過硬體限制並在AMD或Intel GPU上啟用DLSS技術。</x:String>
    <x:String x:Key="TxtNukemHelpTip">Nukem的模組，用AMD FSR 3幀生成取代原生DLSS幀生成，在任何相容的GPU上啟用幀生成。</x:String>

    <x:String x:Key="TxtOptiInstalled">OptiScaler已安裝</x:String>
    <x:String x:Key="TxtOptiNotInstalled">未安裝</x:String>
    <x:String x:Key="TxtNoOptiDetected">未偵測到版本</x:String>
