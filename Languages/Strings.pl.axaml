<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">Ustawienia</x:String>
    <x:String x:Key="TxtSettingsDesc">Zarządzaj preferencjami aplikacji</x:String>
    <x:String x:Key="TxtAppPrefs">Preferencje aplikacji</x:String>
    <x:String x:Key="TxtCacheMgmt">Zarządzanie lokalną pamięcią podręczną</x:String>
    <x:String x:Key="TxtCacheDesc">Wyświetl i usuń pobrane wersje OptiScaler z lokalnego magazynu, aby zwolnić miejsce.</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  Zarządzaj</x:String>
    <x:String x:Key="TxtLanguage">Język aplikacji</x:String>
    <x:String x:Key="TxtLanguageDesc">Zmień język interfejsu użytkownika.</x:String>
    <x:String x:Key="TxtClose">Zamknij</x:String>
    <x:String x:Key="TxtGotIt">Rozumiem</x:String>
    <x:String x:Key="TxtAppRepoTitle">Repozytorium aplikacji</x:String>
    <x:String x:Key="TxtAppRepoDesc">Docelowe repozytorium GitHub dla aktualizacji i opinii (Właściciel/NazwaRepozytorium).</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">Przewodnik</x:String>
    <x:String x:Key="TxtGuideHeader">Jak używać Optiscaler Client</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">Proste kroki do ulepszenia swoich gier</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. Znajdź swoje gry</x:String>
    <x:String x:Key="TxtGuideStep1Desc">Kliknij przycisk 'Skanuj gry', aby aplikacja automatycznie znalazła zainstalowane gry z Steam, Epic, GOG lub Xbox. Zaznacz przycisk 'Dodaj ręcznie', jeśli masz samodzielną grę.</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. Zarządzaj grą</x:String>
    <x:String x:Key="TxtGuideStep2Desc">Obok swojej gry na liście kliknij 'Zarządzaj'. Otworzy się okno pozwalające zainstalować lub zaktualizować modyfikację OptiScaler dla tej konkretnej gry.</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. Zainstaluj OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Desc">Wewnątrz okna zarządzania wybierz swoją wersję OptiScaler i opcje. Użyj 'Automatyczna instalacja' dla szybkiej konfiguracji. Jeśli automatyczna instalacja nie powiedzie się lub nie znajdzie poprawnego pliku wykonywalnego (.exe), użyj 'Ręczna instalacja', aby samodzielnie wybrać plik wykonywalny gry.</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. Graj w grę</x:String>
    <x:String x:Key="TxtGuideStep4Desc">Po zainstalowaniu uruchom swoją grę normalnie. Wewnątrz gry otwórz menu OptiScaler, używając klawisza 'Insert', aby dostosować swoje ustawienia!</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client</x:String>
    <x:String x:Key="TxtBtnScan">⟳  Skanuj gry</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  Dodaj ręcznie</x:String>
    <x:String x:Key="TxtTipSettings">Ustawienia</x:String>
    <x:String x:Key="TxtTipComponent">Wersje komponentów</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  Aktualizuj NukemFG</x:String>
    <x:String x:Key="TxtTipUpdateNukem">Nowa wersja NukemFG jest dostępna. Kliknij, aby dostarczyć zaktualizowaną DLL.</x:String>
    <x:String x:Key="TxtDefaultGpu">Wykrywanie GPU…</x:String>
    <x:String x:Key="TxtManageGame">Zarządzaj</x:String>
    <x:String x:Key="TxtStatusReady">Gotowe</x:String>
    <x:String x:Key="TxtScanningTitle">Skanowanie gier...</x:String>
    <x:String x:Key="TxtScanningDesc">Wyszukiwanie gier na wszystkich platformach...</x:String>
    <x:String x:Key="TxtSearchGames">Szukaj gier...</x:String>
    <x:String x:Key="TxtRemoveGameTip">Usuń ręcznie dodaną grę</x:String>
    <x:String x:Key="TxtRemoveGameTitle">Usuń grę</x:String>
    <x:String x:Key="TxtRemoveGameConfirm">Czy na pewno chcesz usunąć '{0}' z listy?</x:String>

    <!-- ManageCacheWindow -->
    <x:String x:Key="TxtManageCacheTitle">Zarządzaj lokalnymi wersjami</x:String>
    <x:String x:Key="TxtLocalVersions">Lokalne wersje</x:String>
    <x:String x:Key="TxtManageCacheDesc">Zarządzaj pobraną pamięcią podręczną OptiScaler</x:String>
    <x:String x:Key="TxtDownloadedVersions">Pobrane wersje OptiScaler:</x:String>
    <x:String x:Key="TxtDeleteIcon">🗑️ Usuń</x:String>
    <x:String x:Key="TxtNoVersions">Obecnie nie ma pobranych wersji.</x:String>
    <x:String x:Key="TxtToastSuccess">Sukces</x:String>
    <x:String x:Key="TxtConfirmDelTitle">Potwierdź usunięcie</x:String>
    <x:String x:Key="TxtConfirmDelMsg">Czy na pewno chcesz usunąć tę wersję?</x:String>
    <x:String x:Key="TxtCancel">Anuluj</x:String>
    <x:String x:Key="TxtDeletePlain">Usuń</x:String>
    <x:String x:Key="TxtConfirmDelFormat">Czy na pewno chcesz usunąć OptiScaler v{0} z lokalnego magazynu?</x:String>
    <x:String x:Key="TxtDeletedSuccessFormat">OptiScaler v{0} został pomyślnie usunięty.</x:String>
    <x:String x:Key="TxtFailedDeleteFormat">Nie udało się usunąć wersji: {0}</x:String>
    <x:String x:Key="TxtError">Błąd</x:String>
    <x:String x:Key="TxtCurrentSelection">Obecnie wybrane</x:String>
    <x:String x:Key="TxtVersionStored">1 wersja przechowywana lokalnie.</x:String>
    <x:String x:Key="TxtVersionsStored">{0} wersji przechowywanych lokalnie.</x:String>

    <!-- ComponentInfoWindow -->
    <x:String x:Key="TxtComponentTitle">Wersje komponentów</x:String>
    <x:String x:Key="TxtComponentDesc">Zainstalowane wersje zestawu narzędzi OptiScaler</x:String>
    <x:String x:Key="TxtBtnGuide">📖 Przewodnik</x:String>
    <x:String x:Key="TxtUpdateAvail">Aktualizacja dostępna</x:String>
    <x:String x:Key="TxtAppVersionLbl">Wersja aplikacji</x:String>

    <!-- ManageGameWindow -->
    <x:String x:Key="TxtManageGameWindow">Zarządzaj grą</x:String>
    <x:String x:Key="TxtOpenFolder">📂  Otwórz folder</x:String>
    <x:String x:Key="TxtOptiStatus">Status OptiScaler</x:String>
    <x:String x:Key="TxtDetectedComponents">Wykryte komponenty</x:String>
    <x:String x:Key="TxtConfirmUninstallTitle">Potwierdź odinstalowanie</x:String>
    <x:String x:Key="TxtConfirmUninstallMsg">Czy na pewno chcesz odinstalować OptiScaler?&#x0a;Tylko oryginalne pliki z kopii zapasowej zostaną przywrócone.</x:String>
    <x:String x:Key="TxtUninstall">✕ Odinstaluj</x:String>
    <x:String x:Key="TxtVersionLbl">Wersja:</x:String>
    <x:String x:Key="TxtInjectionLbl">Iniekcja:</x:String>
    <x:String x:Key="TxtInstallOpti">✦ Automatyczna instalacja</x:String>
    <x:String x:Key="TxtBtnManualInstall">✦ Ręczna instalacja</x:String>
    <x:String x:Key="TxtUpdateOpti">↑ Automatyczna aktualizacja / Ponowna instalacja</x:String>
    <x:String x:Key="TxtUpdateOptiManual">↑ Ręczna aktualizacja / Ponowna instalacja</x:String>
    <x:String x:Key="TxtFakenvapiTip">Wymagane dla GPU AMD/Intel, aby włączyć DLSS FG z modem Nukem</x:String>
    <x:String x:Key="TxtNukemTip">Mod Nukem DLSSG-to-FSR3 do generowania klatek</x:String>
    <x:String x:Key="TxtFakenvapiHelpTip">Oszukuje grę, aby wykryła kartę graficzną NVIDIA, pozwalając ominąć ograniczenia sprzętowe i włączyć technologie DLSS na GPU AMD lub Intel.</x:String>
    <x:String x:Key="TxtNukemHelpTip">Mod od Nukem, który zastępuje natywne generowanie klatek DLSS generowaniem klatek AMD FSR 3, włączając generowanie klatek na dowolnym kompatybilnym GPU.</x:String>

    <x:String x:Key="TxtOptiInstalled">OptiScaler zainstalowany</x:String>
    <x:String x:Key="TxtOptiNotInstalled">Nie zainstalowany</x:String>
    <x:String x:Key="TxtNoOptiDetected">Nie wykryto wersji</x:String>
    <x:String x:Key="TxtOptiLatest"> (Najnowsza)</x:String>
    <x:String x:Key="TxtInstallingFormat">Pobieranie OptiScaler v{0}... {1}%</x:String>
    <x:String x:Key="TxtExtractingFormat">Ekstrakcja i instalacja v{0}...</x:String>
    <x:String x:Key="TxtInstallSuccessFormat">{0} pomyślnie zainstalowany!</x:String>
    <x:String x:Key="TxtDownloadErrorPrefix">Nie udało się pobrać OptiScaler: {0}</x:String>
    <x:String x:Key="TxtOptiUninstallSuccess">OptiScaler pomyślnie odinstalowany.</x:String>
    <x:String x:Key="TxtOptiUninstallFail">Odinstalowanie nie powiodło się: {0}</x:String>
    <x:String x:Key="TxtInstallSuccessTitle">Instalacja pomyślna</x:String>

    <!-- ManualDownloadDialog -->
    <x:String x:Key="TxtManualTitle">Wymagany plik ręczny</x:String>
    <x:String x:Key="TxtDownloadFrom">Pobierz z: </x:String>
    <x:String x:Key="TxtReqFileLbl">Wymagany plik: </x:String>
    <x:String x:Key="TxtBrowse">Przeglądaj…</x:String>
    <x:String x:Key="TxtConfirmBtn">✓ Potwierdź</x:String>
    
    <x:String x:Key="TxtManualUpdateTitle">🔄 Dostępna ręczna aktualizacja</x:String>
    <x:String x:Key="TxtManualUpdateInst">Nowa wersja NukemFG jest dostępna na Nexus Mods.&#x0a;Proszę pobrać zaktualizowany plik z poniższego linku i wybrać DLL (lub ZIP):</x:String>
    <x:String x:Key="TxtManualUpdateHint">Kliknij 'Przeglądaj', aby wybrać DLL, ZIP lub folder z zaktualizowanym plikiem.</x:String>
    <x:String x:Key="TxtBtnUpdate">Aktualizuj</x:String>
    <x:String x:Key="TxtBtnLater">Później</x:String>

    <!-- Help View Strings -->
    <x:String x:Key="TxtAboutTitle">O programie</x:String>
    <x:String x:Key="TxtFeedbackTitle">Opinie</x:String>
    <x:String x:Key="TxtFeedbackDesc">Jeśli chcesz zgłosić funkcje lub zgłosić błędy, proszę otworzyć issue w repozytorium GitHub.</x:String>
    <x:String x:Key="TxtBuildDateLbl">Data ostatniej kompilacji</x:String>
    <x:String x:Key="TxtCheckUpdatesBtn">Sprawdź aktualizacje</x:String>
    <x:String x:Key="TxtGithubBtn">Repozytorium GitHub</x:String>

    <x:String x:Key="TxtManualReqTitle">⚠️ Wymagany plik ręczny</x:String>
    <x:String x:Key="TxtManualReqInst">NukemFG nie może być pobrany automatycznie.&#x0a;Proszę pobrać plik z Nexus Mods i wybrać DLL (lub ZIP) poniżej:</x:String>
    <x:String x:Key="TxtManualReqHint">Kliknij 'Przeglądaj', aby wybrać bezpośrednio DLL, ZIP lub wyodrębniony folder.</x:String>
    <x:String x:Key="TxtBtnConfirm">Potwierdź</x:String>
    <x:String x:Key="TxtBtnSkip">Pomiń</x:String>

    <!-- CodeBehind additions -->
    <x:String x:Key="TxtCheckingUpdates">Sprawdzanie aktualizacji…</x:String>
    <x:String x:Key="TxtReady">Gotowe</x:String>
    <x:String x:Key="TxtNukemUpdateSuccess">NukemFG pomyślnie zaktualizowany.</x:String>
    <x:String x:Key="TxtActualizacionTitle">Aktualizacja</x:String>
    <x:String x:Key="TxtLoadedGamesFormat">Załadowano {0} gier.</x:String>
    <x:String x:Key="TxtScanningShort">Skanowanie gier...</x:String>
    <x:String x:Key="TxtScanCompleteFormat">Skanowanie zakończone. Łączna liczba gier: {0}</x:String>
