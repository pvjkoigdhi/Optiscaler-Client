    <x:String x:Key="TxtNoGpuTip">Nie wykryto GPU w tym systemie</x:String>
    <x:String x:Key="TxtGpuFail">⚠️ Nie udało się wykryć GPU</x:String>
    <x:String x:Key="TxtGpuFailTipFormat">Błąd wykrywania GPU: {0}</x:String>
    <x:String x:Key="TxtAutoScan">Automatyczny skan przy uruchomieniu</x:String>
    <x:String x:Key="TxtAutoScanDesc">Automatycznie skanuj gry, jeśli lista jest pusta przy uruchomieniu.</x:String>
    <x:String x:Key="TxtAnimations">Włącz animacje</x:String>
    <x:String x:Key="TxtAnimationsDesc">Włącz płynne przejścia i animacje w całym interfejsie</x:String>

    <!-- App Update -->
    <x:String x:Key="TxtUpdateAvailableTitle">Dostępna aktualizacja</x:String>
    <x:String x:Key="TxtUpdateAvailableMsg">Nowa wersja Optiscaler Client jest dostępna (v{0}).&#x0a;Czy chcesz pobrać i zainstalować ją teraz?</x:String>
    <x:String x:Key="TxtUpdatingApp">Aktualizowanie aplikacji...</x:String>
    <x:String x:Key="TxtUpdateReady">Aktualizacja gotowa</x:String>
    <x:String x:Key="TxtUpdateReadyMsg">Aktualizacja została pobrana. Aplikacja teraz uruchomi się ponownie, aby zakończyć instalację.</x:String>
    <x:String x:Key="TxtUpdateError">Błąd aktualizacji</x:String>
    <x:String x:Key="TxtNoUpdateFound">Aplikacja jest już aktualna.</x:String>
    <x:String x:Key="TxtUpdateCheckError">Wystąpił problem podczas sprawdzania aktualizacji. Proszę spróbować ponownie później.</x:String>

</ResourceDictionary>
