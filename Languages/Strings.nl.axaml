    <x:String x:Key="TxtExtractingFormat">v{0} uitpakken en installeren...</x:String>
    <x:String x:Key="TxtInstallSuccessFormat">{0} succesvol geïnstalleerd!</x:String>
    <x:String x:Key="TxtDownloadErrorPrefix">Kan OptiScaler niet downloaden: {0}</x:String>
    <x:String x:Key="TxtOptiUninstallSuccess">OptiScaler succesvol gedeïnstalleerd.</x:String>
    <x:String x:Key="TxtOptiUninstallFail">Deïnstallatie mislukt: {0}</x:String>
    <x:String x:Key="TxtInstallSuccessTitle">Installatie Succesvol</x:String>

    <!-- ManualDownloadDialog -->
    <x:String x:Key="TxtManualTitle">Handmatig Bestand Vereist</x:String>
    <x:String x:Key="TxtDownloadFrom">Download van: </x:String>
    <x:String x:Key="TxtReqFileLbl">Vereist bestand: </x:String>
    <x:String x:Key="TxtBrowse">Bladeren…</x:String>
    <x:String x:Key="TxtConfirmBtn">✓ Bevestig</x:String>
    
    <x:String x:Key="TxtManualUpdateTitle">🔄 Handmatige Update Beschikbaar</x:String>
    <x:String x:Key="TxtManualUpdateInst">Een nieuwe versie van NukemFG is beschikbaar op Nexus Mods.&#x0a;Download het bijgewerkte bestand via de link hieronder en selecteer de DLL (of ZIP):</x:String>
    <x:String x:Key="TxtManualUpdateHint">Klik op 'Bladeren' om de DLL, ZIP of map met het bijgewerkte bestand te selecteren.</x:String>
    <x:String x:Key="TxtBtnUpdate">Update</x:String>
    <x:String x:Key="TxtBtnLater">Later</x:String>

    <!-- Help View Strings -->
    <x:String x:Key="TxtAboutTitle">Over</x:String>
    <x:String x:Key="TxtFeedbackTitle">Feedback</x:String>
    <x:String x:Key="TxtFeedbackDesc">Als u functies wilt aanvragen of bugs wilt rapporteren, open dan een issue in de GitHub repository.</x:String>
    <x:String x:Key="TxtBuildDateLbl">Laatste Build Datum</x:String>
    <x:String x:Key="TxtCheckUpdatesBtn">Controleer updates</x:String>
    <x:String x:Key="TxtGithubBtn">GitHub Repository</x:String>

    <x:String x:Key="TxtManualReqTitle">⚠️ Handmatig Bestand Vereist</x:String>
    <x:String x:Key="TxtManualReqInst">NukemFG kan niet automatisch worden gedownload.&#x0a;Download het bestand van Nexus Mods en selecteer de DLL (of ZIP) hieronder:</x:String>
    <x:String x:Key="TxtManualReqHint">Klik op 'Bladeren' om direct de DLL, ZIP of uitgepakte map te selecteren.</x:String>
    <x:String x:Key="TxtBtnConfirm">Bevestig</x:String>
    <x:String x:Key="TxtBtnSkip">Overslaan</x:String>

