<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">Instellingen</x:String>
    <x:String x:Key="TxtSettingsDesc">Beheer applicatievoorkeuren</x:String>
    <x:String x:Key="TxtAppPrefs">Applicatievoorkeuren</x:String>
    <x:String x:Key="TxtCacheMgmt">Lokale cachebeheer</x:String>
    <x:String x:Key="TxtCacheDesc">Bekijk en verwijder gedownloade OptiScaler versies van uw lokale opslag om ruimte vrij te maken.</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  Beheer</x:String>
    <x:String x:Key="TxtLanguage">Applicatietaal</x:String>
    <x:String x:Key="TxtLanguageDesc">Wijzig de gebruikersinterfacetaal.</x:String>
    <x:String x:Key="TxtClose">Sluiten</x:String>
    <x:String x:Key="TxtGotIt">Begrepen</x:String>
    <x:String x:Key="TxtAppRepoTitle">Applicatie Repository</x:String>
    <x:String x:Key="TxtAppRepoDesc">Doel GitHub repository voor updates en feedback (Eigenaar/RepoNaam).</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">Gids</x:String>
    <x:String x:Key="TxtGuideHeader">Hoe Optiscaler Client te gebruiken</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">Eenvoudige stappen om uw games te verbeteren</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. Vind uw games</x:String>
    <x:String x:Key="TxtGuideStep1Desc">Klik op de 'Scan Games' knop om de app automatisch geïnstalleerde games van Steam, Epic, GOG of Xbox te laten vinden. Vink de 'Voeg handmatig toe' knop aan als u een standalone game heeft.</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. Beheer een game</x:String>
    <x:String x:Key="TxtGuideStep2Desc">Naast uw game in de lijst, klik op 'Beheer'. Er wordt een venster geopend waarmee u de OptiScaler mod voor die specifieke game kunt installeren of updaten.</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. Installeer OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Desc">Binnen het beheervenster, kies uw OptiScaler versie en opties. Gebruik 'Auto Install' voor een snelle setup. Als auto installatie faalt of de juiste uitvoerbare (.exe) niet kan vinden, gebruik 'Handmatige installatie' om zelf de game-uitvoerbare te selecteren.</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. Speel de game</x:String>
    <x:String x:Key="TxtGuideStep4Desc">Na installatie, start uw game normaal. Binnen de game, open het OptiScaler menu met de 'Insert' toets om uw instellingen aan te passen!</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client</x:String>
    <x:String x:Key="TxtBtnScan">⟳  Scan Games</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  Voeg handmatig toe</x:String>
