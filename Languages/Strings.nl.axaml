    <x:String x:Key="TxtAutoScanDesc">Scan automatisch voor games als de lijst leeg is bij opstarten.</x:String>
    <x:String x:Key="TxtAnimations">Activeer animaties</x:String>
    <x:String x:Key="TxtAnimationsDesc">Activeer soepele overgangen en animaties in de hele interface</x:String>

    <!-- App Update -->
    <x:String x:Key="TxtUpdateAvailableTitle">Update Beschikbaar</x:String>
    <x:String x:Key="TxtUpdateAvailableMsg">Een nieuwe versie van Optiscaler Client is beschikbaar (v{0}).&#x0a;Wilt u deze nu downloaden en installeren?</x:String>
    <x:String x:Key="TxtUpdatingApp">App updaten...</x:String>
    <x:String x:Key="TxtUpdateReady">Update Klaar</x:String>
    <x:String x:Key="TxtUpdateReadyMsg">De update is gedownload. De applicatie zal nu herstarten om de installatie te voltooien.</x:String>
    <x:String x:Key="TxtUpdateError">Update Fout</x:String>
    <x:String x:Key="TxtNoUpdateFound">De applicatie is al up-to-date.</x:String>
    <x:String x:Key="TxtUpdateCheckError">Er was een probleem bij het controleren op updates. Probeer het later opnieuw.</x:String>

</ResourceDictionary>
