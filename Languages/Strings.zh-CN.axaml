<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">设置</x:String>
    <x:String x:Key="TxtSettingsDesc">管理应用程序首选项</x:String>
    <x:String x:Key="TxtAppPrefs">应用首选项</x:String>
    <x:String x:Key="TxtCacheMgmt">本地缓存管理</x:String>
    <x:String x:Key="TxtCacheDesc">查看并删除本地存储中已下载的OptiScaler版本以释放空间。</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  管理</x:String>
    <x:String x:Key="TxtLanguage">应用程序语言</x:String>
    <x:String x:Key="TxtLanguageDesc">更改用户界面语言。</x:String>
    <x:String x:Key="TxtClose">关闭</x:String>
    <x:String x:Key="TxtGotIt">知道了</x:String>
    <x:String x:Key="TxtAppRepoTitle">应用仓库</x:String>
    <x:String x:Key="TxtAppRepoDesc">用于更新和反馈的目标GitHub仓库（所有者/仓库名）。</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">指南</x:String>
    <x:String x:Key="TxtGuideHeader">如何使用Optiscaler Client</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">增强游戏的简单步骤</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. 找到您的游戏</x:String>
    <x:String x:Key="TxtGuideStep1Desc">点击"扫描游戏"按钮，让应用程序自动查找从Steam、Epic、GOG或Xbox安装的游戏。如果您有独立游戏，请勾选"手动添加"按钮。</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. 管理游戏</x:String>
    <x:String x:Key="TxtGuideStep2Desc">在列表中您的游戏旁边，点击"管理"。将打开一个窗口，允许您为该特定游戏安装或更新OptiScaler模组。</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. 安装OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Desc">在管理窗口内，选择您的OptiScaler版本和选项。使用"自动安装"进行快速设置。如果自动安装失败或无法找到正确的可执行文件（.exe），请使用"手动安装"自己选择游戏的可执行文件。</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. 玩游戏</x:String>
    <x:String x:Key="TxtGuideStep4Desc">安装后，正常启动您的游戏。在游戏内，使用"Insert"键打开OptiScaler菜单来调整您的设置！</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client</x:String>
    <x:String x:Key="TxtBtnScan">⟳  扫描游戏</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  手动添加</x:String>
    <x:String x:Key="TxtTipSettings">设置</x:String>
    <x:String x:Key="TxtTipComponent">组件版本</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  更新NukemFG</x:String>
    <x:String x:Key="TxtTipUpdateNukem">新的NukemFG版本可用。点击提供更新的DLL。</x:String>
    <x:String x:Key="TxtDefaultGpu">检测GPU中…</x:String>
    <x:String x:Key="TxtManageGame">管理</x:String>
    <x:String x:Key="TxtStatusReady">就绪</x:String>
    <x:String x:Key="TxtScanningTitle">扫描游戏中...</x:String>
    <x:String x:Key="TxtScanningDesc">在所有平台上查找游戏...</x:String>
    <x:String x:Key="TxtSearchGames">搜索游戏...</x:String>
    <x:String x:Key="TxtRemoveGameTip">删除手动添加的游戏</x:String>
    <x:String x:Key="TxtRemoveGameTitle">删除游戏</x:String>
    <x:String x:Key="TxtRemoveGameConfirm">您确定要从列表中删除 '{0}' 吗？</x:String>

    <!-- ManageCacheWindow -->
    <x:String x:Key="TxtManageCacheTitle">管理本地版本</x:String>
    <x:String x:Key="TxtLocalVersions">本地版本</x:String>
    <x:String x:Key="TxtManageCacheDesc">管理已下载的OptiScaler缓存</x:String>
