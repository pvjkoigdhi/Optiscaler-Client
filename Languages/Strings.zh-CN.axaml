    <!-- ComponentInfoWindow -->
    <x:String x:Key="TxtComponentTitle">组件版本</x:String>
    <x:String x:Key="TxtComponentDesc">已安装的OptiScaler工具包版本</x:String>
    <x:String x:Key="TxtBtnGuide">📖 指南</x:String>
