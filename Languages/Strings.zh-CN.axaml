    <!-- ManageGameWindow -->
    <x:String x:Key="TxtManageGameWindow">管理游戏</x:String>
    <x:String x:Key="TxtOpenFolder">📂  打开文件夹</x:String>
    <x:String x:Key="TxtOptiStatus">OptiScaler状态</x:String>
    <x:String x:Key="TxtDetectedComponents">检测到的组件</x:String>
    <x:String x:Key="TxtConfirmUninstallTitle">确认卸载</x:String>
    <x:String x:Key="TxtConfirmUninstallMsg">您确定要卸载OptiScaler吗？&#x0a;只有备份的原始文件将被恢复。</x:String>
    <x:String x:Key="TxtUninstall">✕ 卸载</x:String>
    <x:String x:Key="TxtVersionLbl">版本：</x:String>
    <x:String x:Key="TxtInjectionLbl">注入：</x:String>
    <x:String x:Key="TxtInstallOpti">✦ 自动安装</x:String>
    <x:String x:Key="TxtBtnManualInstall">✦ 手动安装</x:String>
    <x:String x:Key="TxtUpdateOpti">↑ 自动更新 / 重新安装</x:String>
    <x:String x:Key="TxtUpdateOptiManual">↑ 手动更新 / 重新安装</x:String>
    <x:String x:Key="TxtFakenvapiTip">AMD/Intel GPU启用DLSS FG与Nukem模组所需</x:String>
    <x:String x:Key="TxtNukemTip">Nukem的DLSSG-to-FSR3模组用于帧生成</x:String>
    <x:String x:Key="TxtFakenvapiHelpTip">欺骗游戏检测NVIDIA显卡，允许您绕过硬件限制并在AMD或Intel GPU上启用DLSS技术。</x:String>
    <x:String x:Key="TxtNukemHelpTip">Nukem的模组，用AMD FSR 3帧生成替换原生DLSS帧生成，在任何兼容的GPU上启用帧生成。</x:String>

    <x:String x:Key="TxtOptiInstalled">OptiScaler已安装</x:String>
    <x:String x:Key="TxtOptiNotInstalled">未安装</x:String>
