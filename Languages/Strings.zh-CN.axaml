    <x:String x:Key="TxtBuildDateLbl">最后构建日期</x:String>
    <x:String x:Key="TxtCheckUpdatesBtn">检查更新</x:String>
    <x:String x:Key="TxtGithubBtn">GitHub仓库</x:String>

    <x:String x:Key="TxtManualReqTitle">⚠️ 需要手动文件</x:String>
