    <x:String x:Key="TxtAnimationsDesc">Включить плавные переходы и анимации во всем интерфейсе</x:String>

    <!-- App Update -->
    <x:String x:Key="TxtUpdateAvailableTitle">Доступно обновление</x:String>
    <x:String x:Key="TxtUpdateAvailableMsg">Доступна новая версия Optiscaler Client (v{0}).&#x0a;Хотите загрузить и установить ее сейчас?</x:String>
