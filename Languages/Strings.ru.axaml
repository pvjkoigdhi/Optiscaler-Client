<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">Настройки</x:String>
    <x:String x:Key="TxtSettingsDesc">Управление предпочтениями приложения</x:String>
    <x:String x:Key="TxtAppPrefs">Настройки приложения</x:String>
    <x:String x:Key="TxtCacheMgmt">Управление локальным кэшем</x:String>
    <x:String x:Key="TxtCacheDesc">Просмотр и удаление загруженных версий OptiScaler из локального хранилища для освобождения места.</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  Управлять</x:String>
    <x:String x:Key="TxtLanguage">Язык приложения</x:String>
    <x:String x:Key="TxtLanguageDesc">Изменить язык пользовательского интерфейса.</x:String>
    <x:String x:Key="TxtClose">Закрыть</x:String>
    <x:String x:Key="TxtGotIt">Понятно</x:String>
    <x:String x:Key="TxtAppRepoTitle">Репозиторий приложения</x:String>
    <x:String x:Key="TxtAppRepoDesc">Целевой репозиторий GitHub для обновлений и обратной связи (Владелец/ИмяРепозитория).</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">Руководство</x:String>
    <x:String x:Key="TxtGuideHeader">Как использовать Optiscaler Client</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">Простые шаги для улучшения ваших игр</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. Найдите свои игры</x:String>
    <x:String x:Key="TxtGuideStep1Desc">Нажмите кнопку 'Сканировать игры', чтобы приложение автоматически нашло установленные игры из Steam, Epic, GOG или Xbox. Проверьте кнопку 'Добавить вручную', если у вас есть отдельная игра.</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. Управление игрой</x:String>
    <x:String x:Key="TxtGuideStep2Desc">Рядом с вашей игрой в списке нажмите 'Управлять'. Откроется окно, позволяющее установить или обновить мод OptiScaler для этой конкретной игры.</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. Установить OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Desc">В окне управления выберите вашу версию OptiScaler и опции. Используйте 'Автоматическая установка' для быстрой настройки. Если автоматическая установка не удалась или не нашла правильный исполняемый файл (.exe), используйте 'Ручная установка' для выбора исполняемого файла игры самостоятельно.</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. Играть в игру</x:String>
    <x:String x:Key="TxtGuideStep4Desc">После установки запустите вашу игру нормально. Внутри игры откройте меню OptiScaler, используя клавишу 'Insert', чтобы настроить ваши параметры!</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client</x:String>
    <x:String x:Key="TxtBtnScan">⟳  Сканировать игры</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  Добавить вручную</x:String>
    <x:String x:Key="TxtTipSettings">Настройки</x:String>
    <x:String x:Key="TxtTipComponent">Версии компонентов</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  Обновить NukemFG</x:String>
    <x:String x:Key="TxtTipUpdateNukem">Доступна новая версия NukemFG. Нажмите, чтобы предоставить обновленную DLL.</x:String>
    <x:String x:Key="TxtDefaultGpu">Обнаружение GPU…</x:String>
    <x:String x:Key="TxtManageGame">Управлять</x:String>
    <x:String x:Key="TxtStatusReady">Готово</x:String>
    <x:String x:Key="TxtScanningTitle">Сканирование игр...</x:String>
    <x:String x:Key="TxtScanningDesc">Поиск игр на всех платформах...</x:String>
    <x:String x:Key="TxtSearchGames">Поиск игр...</x:String>
    <x:String x:Key="TxtRemoveGameTip">Удалить игру, добавленную вручную</x:String>
    <x:String x:Key="TxtRemoveGameTitle">Удалить игру</x:String>
    <x:String x:Key="TxtRemoveGameConfirm">Вы уверены, что хотите удалить '{0}' из списка?</x:String>

    <!-- ManageCacheWindow -->
    <x:String x:Key="TxtManageCacheTitle">Управление локальными версиями</x:String>
    <x:String x:Key="TxtLocalVersions">Локальные версии</x:String>
    <x:String x:Key="TxtManageCacheDesc">Управление загруженным кэшем OptiScaler</x:String>
    <x:String x:Key="TxtDownloadedVersions">Загруженные версии OptiScaler:</x:String>
    <x:String x:Key="TxtDeleteIcon">🗑️ Удалить</x:String>
    <x:String x:Key="TxtNoVersions">В настоящее время нет загруженных версий.</x:String>
    <x:String x:Key="TxtToastSuccess">Успешно</x:String>
    <x:String x:Key="TxtConfirmDelTitle">Подтвердить удаление</x:String>
    <x:String x:Key="TxtConfirmDelMsg">Вы уверены, что хотите удалить эту версию?</x:String>
    <x:String x:Key="TxtCancel">Отмена</x:String>
    <x:String x:Key="TxtDeletePlain">Удалить</x:String>
    <x:String x:Key="TxtConfirmDelFormat">Вы уверены, что хотите удалить OptiScaler v{0} из локального хранилища?</x:String>
    <x:String x:Key="TxtDeletedSuccessFormat">OptiScaler v{0} успешно удален.</x:String>
    <x:String x:Key="TxtFailedDeleteFormat">Не удалось удалить версию: {0}</x:String>
    <x:String x:Key="TxtError">Ошибка</x:String>
    <x:String x:Key="TxtCurrentSelection">Текущий выбор</x:String>
    <x:String x:Key="TxtVersionStored">1 версия хранится локально.</x:String>
    <x:String x:Key="TxtVersionsStored">{0} версий хранится локально.</x:String>

    <!-- ComponentInfoWindow -->
    <x:String x:Key="TxtComponentTitle">Версии компонентов</x:String>
    <x:String x:Key="TxtComponentDesc">Установленные версии набора инструментов OptiScaler</x:String>
    <x:String x:Key="TxtBtnGuide">📖 Руководство</x:String>
    <x:String x:Key="TxtUpdateAvail">Доступно обновление</x:String>
    <x:String x:Key="TxtAppVersionLbl">Версия приложения</x:String>

    <!-- ManageGameWindow -->
    <x:String x:Key="TxtManageGameWindow">Управление игрой</x:String>
    <x:String x:Key="TxtOpenFolder">📂  Открыть папку</x:String>
    <x:String x:Key="TxtOptiStatus">Статус OptiScaler</x:String>
    <x:String x:Key="TxtDetectedComponents">Обнаруженные компоненты</x:String>
    <x:String x:Key="TxtConfirmUninstallTitle">Подтвердить удаление</x:String>
    <x:String x:Key="TxtConfirmUninstallMsg">Вы уверены, что хотите удалить OptiScaler?&#x0a;Будут восстановлены только оригинальные файлы из резервных копий.</x:String>
    <x:String x:Key="TxtUninstall">✕ Удалить</x:String>
    <x:String x:Key="TxtVersionLbl">Версия:</x:String>
    <x:String x:Key="TxtInjectionLbl">Инъекция:</x:String>
    <x:String x:Key="TxtInstallOpti">✦ Автоматическая установка</x:String>
    <x:String x:Key="TxtBtnManualInstall">✦ Ручная установка</x:String>
    <x:String x:Key="TxtUpdateOpti">↑ Автоматическое обновление / Переустановка</x:String>
    <x:String x:Key="TxtUpdateOptiManual">↑ Ручное обновление / Переустановка</x:String>
    <x:String x:Key="TxtFakenvapiTip">Требуется для GPU AMD/Intel для включения DLSS FG с модом Nukem</x:String>
    <x:String x:Key="TxtNukemTip">Мод Nukem DLSSG-to-FSR3 для генерации кадров</x:String>
    <x:String x:Key="TxtFakenvapiHelpTip">Обманывает игру, заставляя ее обнаруживать видеокарту NVIDIA, позволяя вам обойти аппаратные ограничения и включить технологии DLSS на GPU AMD или Intel.</x:String>
    <x:String x:Key="TxtNukemHelpTip">Мод от Nukem, который заменяет нативную генерацию кадров DLSS на генерацию кадров AMD FSR 3, включая генерацию кадров на любом совместимом GPU.</x:String>

    <x:String x:Key="TxtOptiInstalled">OptiScaler установлен</x:String>
    <x:String x:Key="TxtOptiNotInstalled">Не установлен</x:String>
    <x:String x:Key="TxtNoOptiDetected">Версия не обнаружена</x:String>
    <x:String x:Key="TxtOptiLatest"> (Последняя)</x:String>
    <x:String x:Key="TxtInstallingFormat">Загрузка OptiScaler v{0}... {1}%</x:String>
    <x:String x:Key="TxtExtractingFormat">Извлечение и установка v{0}...</x:String>
    <x:String x:Key="TxtInstallSuccessFormat">{0} успешно установлен!</x:String>
    <x:String x:Key="TxtDownloadErrorPrefix">Не удалось загрузить OptiScaler: {0}</x:String>
