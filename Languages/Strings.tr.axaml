<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">Ayarlar</x:String>
    <x:String x:Key="TxtSettingsDesc">Uygulama tercihlerini yönet</x:String>
    <x:String x:Key="TxtAppPrefs">Uygulama Tercihleri</x:String>
    <x:String x:Key="TxtCacheMgmt">Yerel Önbellek Yönetimi</x:String>
    <x:String x:Key="TxtCacheDesc">Yerel depolamadan indirilen OptiScaler sürümlerini görüntüle ve silerek alan boşalt.</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  Yönet</x:String>
    <x:String x:Key="TxtLanguage">Uygulama Dili</x:String>
    <x:String x:Key="TxtLanguageDesc">Kullanıcı arayüzü dilini değiştir.</x:String>
    <x:String x:Key="TxtClose">Kapat</x:String>
    <x:String x:Key="TxtGotIt">Anladım</x:String>
    <x:String x:Key="TxtAppRepoTitle">Uygulama Deposu</x:String>
    <x:String x:Key="TxtAppRepoDesc">Güncellemeler ve geri bildirim için hedef GitHub deposu (Sahip/DepoAdı).</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">Kılavuz</x:String>
    <x:String x:Key="TxtGuideHeader">Optiscaler Client Nasıl Kullanılır</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">Oyunlarınızı geliştirmek için basit adımlar</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. Oyunlarınızı Bulun</x:String>
    <x:String x:Key="TxtGuideStep1Desc">'Oyunları Tara' düğmesine tıklayarak uygulamanın Steam, Epic, GOG veya Xbox'tan yüklenen oyunları otomatik olarak bulmasını sağlayın. Bağımsız bir oyununuz varsa 'Manuel Ekle' düğmesini işaretleyin.</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. Oyunu Yönet</x:String>
    <x:String x:Key="TxtGuideStep2Desc">Listedeki oyununuzun yanında 'Yönet' öğesine tıklayın. Bu özel oyun için OptiScaler modunu yüklemenize veya güncellemenize izin veren bir pencere açılacaktır.</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. OptiScaler Yükleyin</x:String>
    <x:String x:Key="TxtGuideStep3Desc">Yönetim penceresi içinde OptiScaler sürümünüzü ve seçeneklerinizi seçin. Hızlı kurulum için 'Otomatik Yükle' kullanın. Otomatik yükleme başarısız olursa veya doğru yürütülebilir dosyayı (.exe) bulamazsa, oyunun yürütülebilir dosyasını kendiniz seçmek için 'Manuel Yükle' kullanın.</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. Oyunu Oynayın</x:String>
    <x:String x:Key="TxtGuideStep4Desc">Yüklemeden sonra oyununuzu normal şekilde başlatın. Oyun içinde 'Insert' tuşunu kullanarak OptiScaler menüsünü açın ve ayarlarınızı ayarlayın!</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client</x:String>
    <x:String x:Key="TxtBtnScan">⟳  Oyunları Tara</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  Manuel Ekle</x:String>
