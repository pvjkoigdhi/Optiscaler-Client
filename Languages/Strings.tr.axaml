    <x:String x:Key="TxtManualUpdateTitle">🔄 Manuel Güncelleme Mevcut</x:String>
    <x:String x:Key="TxtManualUpdateInst">NukemFG'nin yeni bir sürümü Nexus Mods'ta mevcut.&#x0a;Lütfen aşağıdaki linkten güncellenmiş dosyayı indirin ve DLL'yi (veya ZIP'i) seçin:</x:String>
    <x:String x:Key="TxtManualUpdateHint">'Gözat' düğmesine tıklayarak güncellenmiş dosyalı DLL, ZIP veya klasörü seçin.</x:String>
    <x:String x:Key="TxtBtnUpdate">Güncelle</x:String>
    <x:String x:Key="TxtBtnLater">Sonra</x:String>

    <!-- Help View Strings -->
    <x:String x:Key="TxtAboutTitle">Hakkında</x:String>
    <x:String x:Key="TxtFeedbackTitle">Geri Bildirim</x:String>
    <x:String x:Key="TxtFeedbackDesc">Özellik istemek veya hata bildirmek isterseniz, lütfen GitHub deposunda bir issue açın.</x:String>
    <x:String x:Key="TxtBuildDateLbl">Son Derleme Tarihi</x:String>
    <x:String x:Key="TxtCheckUpdatesBtn">Güncellemeleri kontrol et</x:String>
