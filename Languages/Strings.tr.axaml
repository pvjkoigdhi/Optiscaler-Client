    <x:String x:Key="TxtTipComponent">Bileşen Sürümleri</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  NukemFG'yi Güncelle</x:String>
    <x:String x:Key="TxtTipUpdateNukem">Yeni NukemFG sürümü mevcut. Güncellenmiş DLL'yi sağlamak için tıklayın.</x:String>
