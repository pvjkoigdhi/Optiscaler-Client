<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">Paramètres</x:String>
    <x:String x:Key="TxtSettingsDesc">Gérer les préférences de l'application</x:String>
    <x:String x:Key="TxtAppPrefs">Préférences de l'application</x:String>
    <x:String x:Key="TxtCacheMgmt">Gestion du cache local</x:String>
    <x:String x:Key="TxtCacheDesc">Afficher et supprimer les versions d'OptiScaler téléchargées de votre stockage local pour libérer de l'espace.</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  Gérer</x:String>
    <x:String x:Key="TxtLanguage">Langue de l'application</x:String>
    <x:String x:Key="TxtLanguageDesc">Changer la langue de l'interface utilisateur.</x:String>
    <x:String x:Key="TxtClose">Fermer</x:String>
    <x:String x:Key="TxtGotIt">Compris</x:String>
    <x:String x:Key="TxtAppRepoTitle">Dépôt de l'application</x:String>
    <x:String x:Key="TxtAppRepoDesc">Dépôt GitHub cible pour les mises à jour et les commentaires (Propriétaire/NomDépôt).</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">Guide</x:String>
    <x:String x:Key="TxtGuideHeader">Comment utiliser Optiscaler Client</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">Étapes simples pour améliorer vos jeux</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. Trouvez vos jeux</x:String>
    <x:String x:Key="TxtGuideStep1Desc">Cliquez sur le bouton 'Scanner les jeux' pour laisser l'application trouver automatiquement les jeux installés sur Steam, Epic, GOG ou Xbox. Cochez le bouton 'Ajouter manuellement' si vous avez un jeu autonome.</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. Gérer un jeu</x:String>
    <x:String x:Key="TxtGuideStep2Desc">À côté de votre jeu dans la liste, cliquez sur 'Gérer'. Une fenêtre s'ouvrira vous permettant d'installer ou de mettre à jour le mod OptiScaler pour ce jeu spécifique.</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. Installer OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Desc">Dans la fenêtre de gestion, choisissez votre version OptiScaler et les options. Utilisez 'Installation automatique' pour une configuration rapide. Si l'installation automatique échoue ou ne trouve pas l'exécutable correct (.exe), utilisez 'Installation manuelle' pour sélectionner vous-même l'exécutable du jeu.</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. Jouer au jeu</x:String>
    <x:String x:Key="TxtGuideStep4Desc">Une fois installé, lancez votre jeu normalement. Dans le jeu, ouvrez le menu OptiScaler en utilisant la touche 'Insert' pour ajuster vos paramètres !</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client</x:String>
    <x:String x:Key="TxtBtnScan">⟳  Scanner les jeux</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  Ajouter manuellement</x:String>
    <x:String x:Key="TxtTipSettings">Paramètres</x:String>
    <x:String x:Key="TxtTipComponent">Versions des composants</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  Mettre à jour NukemFG</x:String>
    <x:String x:Key="TxtTipUpdateNukem">Nouvelle version de NukemFG disponible. Cliquez pour fournir la DLL mise à jour.</x:String>
    <x:String x:Key="TxtDefaultGpu">Détection du GPU…</x:String>
    <x:String x:Key="TxtManageGame">Gérer</x:String>
    <x:String x:Key="TxtStatusReady">Prêt</x:String>
    <x:String x:Key="TxtScanningTitle">Scan des jeux en cours...</x:String>
    <x:String x:Key="TxtScanningDesc">Recherche de jeux sur toutes les plateformes...</x:String>
    <x:String x:Key="TxtSearchGames">Rechercher des jeux...</x:String>
    <x:String x:Key="TxtRemoveGameTip">Supprimer le jeu ajouté manuellement</x:String>
    <x:String x:Key="TxtRemoveGameTitle">Supprimer le jeu</x:String>
    <x:String x:Key="TxtRemoveGameConfirm">Êtes-vous sûr de vouloir supprimer '{0}' de la liste ?</x:String>

    <!-- ManageCacheWindow -->
    <x:String x:Key="TxtManageCacheTitle">Gérer les versions locales</x:String>
    <x:String x:Key="TxtLocalVersions">Versions locales</x:String>
