    <x:String x:Key="TxtConfirmDelMsg">Êtes-vous sûr de vouloir supprimer cette version ?</x:String>
    <x:String x:Key="TxtCancel">Annuler</x:String>
    <x:String x:Key="TxtDeletePlain">Supprimer</x:String>
    <x:String x:Key="TxtConfirmDelFormat">Êtes-vous sûr de vouloir supprimer OptiScaler v{0} du stockage local ?</x:String>
    <x:String x:Key="TxtDeletedSuccessFormat">OptiScaler v{0} supprimé avec succès.</x:String>
