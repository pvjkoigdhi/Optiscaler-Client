    <x:String x:Key="TxtAutoScanDesc">Scanner automatiquement les jeux si la liste est vide au démarrage.</x:String>
    <x:String x:Key="TxtAnimations">Activer les animations</x:String>
    <x:String x:Key="TxtAnimationsDesc">Activer les transitions fluides et les animations dans toute l'interface</x:String>

    <!-- App Update -->
    <x:String x:Key="TxtUpdateAvailableTitle">Mise à jour disponible</x:String>
    <x:String x:Key="TxtUpdateAvailableMsg">Une nouvelle version d'Optiscaler Client est disponible (v{0}).&#x0a;Voulez-vous la télécharger et l'installer maintenant ?</x:String>
    <x:String x:Key="TxtUpdatingApp">Mise à jour de l'application...</x:String>
    <x:String x:Key="TxtUpdateReady">Mise à jour prête</x:String>
    <x:String x:Key="TxtUpdateReadyMsg">La mise à jour a été téléchargée. L'application va maintenant redémarrer pour terminer l'installation.</x:String>
    <x:String x:Key="TxtUpdateError">Erreur de mise à jour</x:String>
    <x:String x:Key="TxtNoUpdateFound">L'application est déjà à jour.</x:String>
    <x:String x:Key="TxtUpdateCheckError">Un problème est survenu lors de la vérification des mises à jour. Veuillez réessayer plus tard.</x:String>

