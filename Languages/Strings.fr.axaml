    <x:String x:Key="TxtVersionStored">1 version stockée localement.</x:String>
    <x:String x:Key="TxtVersionsStored">{0} versions stockées localement.</x:String>

    <!-- ComponentInfoWindow -->
    <x:String x:Key="TxtComponentTitle">Versions des composants</x:String>
