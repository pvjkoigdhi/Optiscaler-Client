    <!-- ManualDownloadDialog -->
    <x:String x:Key="TxtManualTitle">Fichier manuel requis</x:String>
    <x:String x:Key="TxtDownloadFrom">Télécharger depuis : </x:String>
    <x:String x:Key="TxtReqFileLbl">Fichier requis : </x:String>
    <x:String x:Key="TxtBrowse">Parcourir…</x:String>
    <x:String x:Key="TxtConfirmBtn">✓ Confirmer</x:String>
    
    <x:String x:Key="TxtManualUpdateTitle">🔄 Mise à jour manuelle disponible</x:String>
    <x:String x:Key="TxtManualUpdateInst">Une nouvelle version de NukemFG est disponible sur Nexus Mods.&#x0a;Veuillez télécharger le fichier mis à jour depuis le lien ci-dessous et sélectionner la DLL (ou ZIP) :</x:String>
    <x:String x:Key="TxtManualUpdateHint">Cliquez sur 'Parcourir' pour sélectionner la DLL, le ZIP ou le dossier avec le fichier mis à jour.</x:String>
    <x:String x:Key="TxtBtnUpdate">Mettre à jour</x:String>
    <x:String x:Key="TxtBtnLater">Plus tard</x:String>

    <!-- Help View Strings -->
    <x:String x:Key="TxtAboutTitle">À propos</x:String>
    <x:String x:Key="TxtFeedbackTitle">Commentaires</x:String>
    <x:String x:Key="TxtFeedbackDesc">Si vous souhaitez demander des fonctionnalités ou signaler des bugs, veuillez ouvrir une issue dans le dépôt GitHub.</x:String>
    <x:String x:Key="TxtBuildDateLbl">Date de dernière compilation</x:String>
    <x:String x:Key="TxtCheckUpdatesBtn">Vérifier les mises à jour</x:String>
    <x:String x:Key="TxtGithubBtn">Dépôt GitHub</x:String>

    <x:String x:Key="TxtManualReqTitle">⚠️ Fichier manuel requis</x:String>
    <x:String x:Key="TxtManualReqInst">NukemFG ne peut pas être téléchargé automatiquement.&#x0a;Veuillez télécharger le fichier depuis Nexus Mods et sélectionner la DLL (ou ZIP) ci-dessous :</x:String>
    <x:String x:Key="TxtManualReqHint">Cliquez sur 'Parcourir' pour sélectionner la DLL directement, un ZIP ou le dossier extrait.</x:String>
    <x:String x:Key="TxtBtnConfirm">Confirmer</x:String>
    <x:String x:Key="TxtBtnSkip">Ignorer</x:String>

    <!-- CodeBehind additions -->
