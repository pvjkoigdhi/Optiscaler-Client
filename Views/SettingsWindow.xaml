<Window x:Class="OptiscalerClient.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource TxtSettingsTitle}"
        Height="420" Width="540"
        MinHeight="380" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BrBgBase}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        Icon="/Assets/icon.png">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0"
                Background="{StaticResource BrBgSurface}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="{DynamicResource TxtSettingsTitle}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource BrTextPrimary}"/>
                <TextBlock Text="{DynamicResource TxtSettingsDesc}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextSecondary}" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0" >
            <StackPanel Margin="24">
            
            <TextBlock Text="{DynamicResource TxtAppPrefs}"
                       Foreground="{StaticResource BrTextSecondary}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <Border Background="{StaticResource BrBgCard}"
                    BorderBrush="{StaticResource BrBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusLarge}"
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource TxtCacheMgmt}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"/>
                        <TextBlock Text="{DynamicResource TxtCacheDesc}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,16,0"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                    </StackPanel>
                    
                    <Button x:Name="BtnManageCache"
                            Grid.Column="1"
                            Content="{DynamicResource TxtManage}"
                            Style="{StaticResource BtnBase}"
                            Padding="16,8"
                            VerticalAlignment="Center"
                            Click="BtnManageCache_Click"/>
                </Grid>
            </Border>

            <Border Background="{StaticResource BrBgCard}"
                    BorderBrush="{StaticResource BrBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusLarge}"
                    Padding="20,16"
                    Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource TxtLanguage}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"/>
                        <TextBlock Text="{DynamicResource TxtLanguageDesc}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,16,0"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                    </StackPanel>
                    
                    <ComboBox x:Name="CmbLanguage"
                              Grid.Column="1"
                              Width="160"
                              VerticalAlignment="Center"
                              SelectionChanged="CmbLanguage_SelectionChanged">
                        <ComboBoxItem Tag="en" Content="English"/>
                        <ComboBoxItem Tag="es" Content="Español"/>
                        <ComboBoxItem Tag="pt-BR" Content="Português (Brasil)"/>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Background="{StaticResource BrBgCard}"
                    BorderBrush="{StaticResource BrBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusLarge}"
                    Padding="20,16"
                    Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource TxtAppRepoTitle}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"/>
                        <TextBlock Text="{DynamicResource TxtAppRepoDesc}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,16,0"
                                   FontSize="{StaticResource FontSizeCaption}"/>
                    </StackPanel>
                    
                    <TextBox x:Name="TxtAppRepo"
                             Grid.Column="1"
                             Width="160"
                             VerticalAlignment="Center"
                             LostFocus="TxtAppRepo_LostFocus"/>
                </Grid>
            </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource TxtClose}" IsCancel="True" Style="{StaticResource BtnBase}" Padding="16,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
